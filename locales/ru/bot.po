msgstr "📦 *Ваши капсулы:*"

msgid "list_empty"
msgstr "📭 У вас нет капсул!"

msgid "status_opened"
msgstr "✅ Открыта"

msgid "status_closed"
msgstr "🔒 Закрыта"

msgid "content_text_files"
msgstr "📝+📎({count})"

