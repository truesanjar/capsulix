msgstr "{days}д {hours}ч {minutes}мин осталось"

msgid "no_unopened_capsules"
msgstr "📭 У вас нет неоткрытых капсул!"

msgid "delete_confirm"
msgstr "🗑 *Выберите капсулу для удаления:*"

msgid "cancel_delete"
msgstr "❌ Отмена"

msgid "delete_cancelled"
msgstr "✅ Операция удаления отменена."

msgid "delete_success"
msgstr "✅ Капсула успешно удалена!"

msgid "main_menu_returned"
msgstr "👆 Главное меню возвращено:"

msgid "capsule_not_found"
msgstr "❌ Ошибка: Капсула не найдена!"

msgid "capsule_opened"
msgstr "⏰ *Капсула Времени открылась!*\n\n📅 Дата создания: {created_date}\n💭 Сообщение:\n{message}"

msgid "files_opened"
msgstr "⏰ *Капсула Времени открылась!*\n📅 Дата создания: {created_date}\n📦 Отправлено {files_count} файл(ов)! 🎁"

msgid "photo_from_past"
msgstr "📸 Ваше фото из прошлого! ⏰"

msgid "video_from_past"
msgstr "🎬 Ваше видео из прошлого! ⏰"

msgid "recording_from"
msgstr "🎵 Запись {date}"

msgid "file_from_past"
msgstr "📁 Ваш файл из прошлого! ⏰"

msgid "size_limit_exceeded"
msgstr ""
"❌ *Размер капсулы превышен!*\n"
"\n"
"📦 Максимальный размер: {max_size}\n"
"📊 Текущий размер: {current_size}\n"
"📁 Размер нового файла: {file_size}\n"
"💡 Осталось: {remaining}\n"
"\n"
"Пожалуйста, отправьте файл меньшего размера или нажмите '✅ Готово!'."

msgid "size_limit_final_error"
msgstr ""
"❌ *Капсула слишком большая!*\n"
"\n"
"📦 Общий размер: {total_size}\n"
"⚠️ Максимально разрешено: {max_size}\n"
"📈 Превышение: {excess}\n"
"\n"
"Пожалуйста, удалите какой-нибудь файл или выберите файлы меньшего размера."

msgid "welcome_back"
msgstr "Добро пожаловать! 🥰"

msgid "timezone_prompt"
msgstr "🕐 <b>Пожалуйста, выберите ваш часовой пояс:</b>\n\nВы сможете изменить часовой пояс позже из главного меню."

msgid "skip_timezone"
msgstr "⏩ Пропустить (Таджикистан UTC+5)"

msgid "timezone_set"
msgstr "✅ Ваш часовой пояс установлен: {tz_name}"